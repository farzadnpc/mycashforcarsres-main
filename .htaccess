RewriteEngine On

# 1. Redirect /index.html to the clean root domain (/)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.html\ HTTP/
RewriteRule ^index\.html$ / [R=301,L]

# 2. Redirect any other .html files to their clean URL versions (e.g., /toyota.html -> /toyota)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /+(.*)\.html\ HTTP/
RewriteRule ^(.*)\.html$ /$1 [R=301,L]

# 3. Silently serve the .html file in the background when a clean URL is requested
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]